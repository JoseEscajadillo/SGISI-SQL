@page
@model LoginModel
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = "_LoginLayout";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="card shadow-sm" style="width: 380px;">
        <div class="card-body p-4">
            <h4 class="card-title mb-3 text-center">SGISI</h4>
            <p class="text-muted text-center mb-4">Sistema de Gestión de Incidentes</p>

            @if (Model.Error != null)
            {
                <div class="alert alert-danger py-2">@Model.Error</div>
            }

            <form method="post">
                <div class="mb-3">
                    <label class="form-label">Usuario</label>
                    <input asp-for="Usuario" class="form-control" autofocus />
                </div>
                <div class="mb-3">
                    <label class="form-label">Contraseña</label>
                    <input asp-for="Contrasena" type="password" class="form-control" />
                </div>
                <button type="submit" class="btn btn-primary w-100">Ingresar</button>
            </form>
        </div>
    </div>
</div>
