@model System.Data.DataTable
@* Renderiza cualquier DataTable como tabla HTML. Equivalente web del
   DataGridView que usa la app de escritorio. *@
@if (Model == null || Model.Rows.Count == 0)
{
    <p class="text-muted">No hay datos para mostrar.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-sm table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    @foreach (System.Data.DataColumn col in Model.Columns)
                    {
                        <th>@col.ColumnName</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (System.Data.DataRow row in Model.Rows)
                {
                    <tr>
                        @foreach (System.Data.DataColumn col in Model.Columns)
                        {
                            <td>@row[col]</td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <p class="text-muted small">@Model.Rows.Count fila(s)</p>
}
