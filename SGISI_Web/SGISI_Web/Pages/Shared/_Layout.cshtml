@using SGISI_Web.Services
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SGISI</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SGISI_Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">SGISI</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Incidentes">Incidentes</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Resumen">Resumen (Cursor)</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Bitacora">Bitácora</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Analistas">Analistas (DDM)</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Más entidades
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-page="/Organizaciones">Organizaciones</a></li>
                                <li><a class="dropdown-item" asp-page="/Activos">Activos (DDM)</a></li>
                                <li><a class="dropdown-item" asp-page="/Vulnerabilidades">Vulnerabilidades (DDM)</a></li>
                                <li><a class="dropdown-item" asp-page="/Alertas">Alertas</a></li>
                                <li><a class="dropdown-item" asp-page="/IncidenteActivo">Incidente-Activo</a></li>
                                <li><a class="dropdown-item" asp-page="/Supervision">Supervisión (DDM)</a></li>
                                <li><a class="dropdown-item" asp-page="/Reportes">Reportes</a></li>
                            </ul>
                        </li>
                    </ul>
                    @if (Context.Session.EstaLogueado())
                    {
                        <span class="navbar-text me-3">
                            Sesión: <strong>@Context.Session.ObtenerNombreUsuario()</strong>
                            —
                            @if (Context.Session.ObtenerEsAdministrador())
                            {
                                <span class="text-success">Administrador</span>
                            }
                            else
                            {
                                <span class="text-warning">Cliente (datos enmascarados)</span>
                            }
                        </span>
                        <a class="btn btn-outline-secondary btn-sm" asp-page="/Logout">Cerrar sesión</a>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - SGISI - Sistema de Gestión de Incidentes de Seguridad Informática
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
