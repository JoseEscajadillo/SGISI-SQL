@page
@model ActivosModel
@{
    ViewData["Title"] = "Activos (DDM)";
}

<h2>Activos</h2>
<p class="text-muted">
    Enmascaramiento Dinámico de Datos (DDM): la dirección IP y el sistema operativo se muestran
    reales solo si tu usuario tiene el permiso <code>UNMASK</code>, ya que exponer la huella
    técnica exacta de un activo facilita el reconocimiento previo a un ataque.
</p>

@if (Model.Error != null)
{
    <div class="alert alert-danger">@Model.Error</div>
}

<partial name="_TablaDatos" model="Model.Tabla" />
